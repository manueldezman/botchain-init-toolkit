# Copy this file to .env and fill in the private key before starting the server.
# Never commit the real .env file.
#
# Defaults below are BOT Chain TESTNET values, verified against
# https://dev-docs.botchain.ai/docs/Developers/quick-guide/ on 2026-07-08.
# Re-verify if it's been a while — see ../FEEDBACK.md for known issues
# with that docs site (contradictory faucet instructions, etc).

BOTCHAIN_RPC_URL=https://rpc.bohr.life
BOTCHAIN_CHAIN_ID=968
# No explorer API is documented anywhere in BOT Chain's official docs.
# This URL is the explorer UI, not a verified API base — fetch_explorer_state
# may need adjusting once you've confirmed the explorer's actual API shape.
BOTCHAIN_EXPLORER_API=https://scan.bohr.life
BOTCHAIN_NETWORK_LABEL=BOT Chain Testnet

# Testnet-only development key. Never put a mainnet key here.
BOTCHAIN_PRIVATE_KEY=
